# LaSource Configuration Example
# Copy this file to .env and update with your actual values

# =============================================================================
# AI PROVIDER CONFIGURATION
# =============================================================================

# Provider selection: azure-openai, anthropic, gemini, or cohere
LA_SOURCE_PROVIDER=azure-openai

# Model name to use with the provider
# Azure OpenAI: gpt-4o, gpt-35-turbo, o1-preview, etc.
LA_SOURCE_MODEL=gpt-4o

# =============================================================================
# AZURE OPENAI CONFIGURATION
# =============================================================================

# Azure OpenAI endpoint URL
# Format: https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure tenant ID (for authentication)
AZURE_TENANT_ID=your-tenant-id-here

# Azure subscription ID (for resource management)
AZURE_SUBSCRIPTION_ID=your-subscription-id-here

# =============================================================================
# API KEY CONFIGURATION (if not using Managed Identity)
# =============================================================================

# Anthropic API Key (required if using anthropic provider)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Google Gemini API Key (required if using gemini provider)
GEMINI_API_KEY=your-gemini-key-here

# Cohere API Key (required if using cohere provider)
# COHERE_API_KEY=your-cohere-key-here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application environment: development, staging, or production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Application host (for server binding)
APP_HOST=0.0.0.0

# Application port
APP_PORT=8000

# Number of worker processes (for production)
APP_WORKERS=4

# Application URL (for self-referential links)
APP_URL=http://localhost:8000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT token expiration in seconds
JWT_EXPIRATION=3600

# Rate limiter configuration
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_RATE=20.0

# =============================================================================
# DATABASE CONFIGURATION (if applicable)
# =============================================================================

# Database URL for audit logging
# DATABASE_URL=postgresql://user:password@localhost/lasource_db

# =============================================================================
# TELEMETRY CONFIGURATION
# =============================================================================

# Azure Application Insights instrumentation key
# APPLICATION_INSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key

# OpenTelemetry endpoint (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable debug mode (verbose logging)
DEBUG=false

# Enable hot reload for development
HOT_RELOAD=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable PII scrubbing
ENABLE_PII_SCRUBBING=true

# Enable keyword blocking
ENABLE_KEYWORD_BLOCKING=true

# Enable rate limiting
ENABLE_RATE_LIMITING=true

# Enable correlation ID tracking
ENABLE_CORRELATION_ID=true
